# Server Configuration
PORT=8080
LOG_LEVEL=info
LOG_FORMAT=console

# Database Configuration
# SQLite (default for development)
DB_DRIVER=sqlite
DB_DSN=./data/app.db

# Seed default providers on startup
SEED=false
SEED_ONLY=false

# PostgreSQL (uncomment to use)
# DB_DRIVER=postgres
# DB_DSN=postgres://user:password@localhost:5432/dbname?sslmode=disable

# ZID Configuration (optional, will use defaults if not set)
# ZID_MASTER_KEY=your-32-byte-master-key-here-change-in-production
# ZID_TWEAK=v1|skm|dev
